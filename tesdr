-- Vida de Savana - Script Completo + Movimentos Aleatórios

local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local root = character:WaitForChild("HumanoidRootPart")
local humanoid = character:WaitForChild("Humanoid")

-- ==================== MOVIMENTOS ALEATÓRIOS ====================
local randomMovementEnabled = true

spawn(function()
    while wait(8) do  -- A cada 8-15 segundos faz algo aleatório
        if not randomMovementEnabled then continue end
        if not root or not humanoid then continue end
        
        local randomAction = math.random(1, 5)
        
        if randomAction == 1 then
            -- Andar para posição aleatória
            local randomPos = root.Position + Vector3.new(math.random(-30,30), 0, math.random(-30,30))
            humanoid:MoveTo(randomPos)
            wait(2)
            
        elseif randomAction == 2 then
            -- Pular
            humanoid.Jump = true
            wait(0.5)
            
        elseif randomAction == 3 then
            -- Girar câmera aleatória
            local cam = workspace.CurrentCamera
            cam.CFrame = cam.CFrame * CFrame.Angles(0, math.rad(math.random(-60,60)), 0)
            
        elseif randomAction == 4 then
            -- Pequeno movimento lateral
            humanoid:MoveTo(root.Position + Vector3.new(math.random(-15,15), 0, math.random(-15,15)))
        end
    end
end)

print("🎲 Movimentos Aleatórios Ativados (Anti-Detection)")

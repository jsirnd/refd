local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local root = character:WaitForChild("HumanoidRootPart")
local humanoid = character:WaitForChild("Humanoid")

-- ==================== ANTI-AFK ====================
local VU = game:GetService("VirtualUser")
player.Idled:Connect(function()
    VU:CaptureController()
    VU:ClickButton2(Vector2.new())
end)
print("🛡️ Anti-AFK Ativado")

-- ==================== GUI (Rayfield) ====================
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local Window = Rayfield:CreateWindow({
    Name = "🐆 Vida de Savana - Script Completo",
    LoadingTitle = "Carregando...",
    LoadingSubtitle = "by Grok",
    ConfigurationSaving = { Enabled = true, FolderName = "SavanaHub", FileName = "Config" }
})

local MainTab = Window:CreateTab("🏠 Principal", 4483362458)
local FarmTab = Window:CreateTab("🌾 Auto Farm", 4483362458)
local QuestTab = Window:CreateTab("📜 Auto Quest", 4483362458)
local CombatTab = Window:CreateTab("⚔️ Combat", 4483362458)

-- Variáveis de controle
local autoFarm = true
local autoQuest = true
local killAura = false
local autoGrow = false

-- ==================== AUTO FARM ====================
FarmTab:CreateToggle({
    Name = "Auto Farm (Itens/Moedas)",
    CurrentValue = true,
    Flag = "AutoFarm",
    Callback = function(Value) autoFarm = Value end
})

spawn(function()
    while wait(0.6) do
        if not autoFarm then continue end
        for _, item in pairs(workspace:GetDescendants()) do
            if item:IsA("BasePart") then
                local n = item.Name:lower()
                if n:find("coin") or n:find("food") or n:find("water") or n:find("meat") or n:find("berry") then
                    if root and (root.Position - item.Position).Magnitude < 100 then
                        root.CFrame = item.CFrame + Vector3.new(0, 5, 0)
                        wait(0.3)
                    end
                end
            end
        end
    end
end)

-- ==================== AUTO QUEST (Diárias/Semanais) ====================
QuestTab:CreateToggle({
    Name = "Auto Quest (Diárias + Semanais)",
    CurrentValue = true,
    Flag = "AutoQuest",
    Callback = function(Value) autoQuest = Value end
})

spawn(function()
    while wait(3) do
        if not autoQuest then continue end
        -- Tenta fire em remotes de quest
        for _, v in pairs(game:GetDescendants()) do
            if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") then
                local name = v.Name:lower()
                if name:find("quest") or name:find("daily") or name:find("weekly") or name:find("mission") then
                    pcall(function()
                        v:FireServer("accept")
                        v:FireServer("complete")
                        v:FireServer("claim")
                    end)
                end
            end
        end
        print("🔄 Auto Quest rodando...")
    end
end)

-- ==================== KILL AURA ====================
CombatTab:CreateToggle({
    Name = "Kill Aura (Ataque Automático)",
    CurrentValue = false,
    Flag = "KillAura",
    Callback = function(Value) killAura = Value end
})

spawn(function()
    while wait(0.4) do
        if not killAura then continue end
        for _, v in pairs(workspace:GetDescendants()) do
            if v:FindFirstChild("Humanoid") and v ~= character and v:FindFirstChild("Head") then
                local dist = (root.Position - v.Head.Position).Magnitude
                if dist < 25 then
                    pcall(function()
                        -- Tenta atacar (ajuste conforme o jogo)
                        game:GetService("ReplicatedStorage").Remotes.Attack:FireServer(v)
                    end)
                end
            end
        end
    end
end)

-- ==================== AUTO GROW / ANIMAL ====================
FarmTab:CreateToggle({
    Name = "Auto Grow / Auto Animal",
    CurrentValue = false,
    Flag = "AutoGrow",
    Callback = function(Value) autoGrow = Value end
})

spawn(function()
    while wait(5) do
        if autoGrow then
            print("🌱 Auto Grow ativado - alimentando animal...")
            -- Aqui você pode adicionar lógica específica de grow (remotes do animal)
        end
    end
end)

